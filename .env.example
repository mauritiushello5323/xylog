# ── 高德地图 API Key ─────────────────────────────────────────────
# 注册地址：https://lbs.amap.com/  → 控制台 → 创建应用 → 添加 Key（Web端JS API）
# 需要在"白名单域名"中添加你的 GitHub Pages 地址，例如：mauritiushello5323.github.io
VITE_AMAP_KEY=529272372b5ea9a2d12d482b399d1334

# ── Supabase ─────────────────────────────────────────────────────
# 在 Supabase 后台 → Project Settings → API 页面复制这两项
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── 管理员密码 ────────────────────────────────────────────────────
# 访问 /#/admin 时输入的密码，自己设置即可
VITE_ADMIN_PASSWORD=your-secret-password
